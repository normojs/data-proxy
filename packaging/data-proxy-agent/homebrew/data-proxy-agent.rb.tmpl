class DataProxyAgent < Formula
  desc "Data Proxy local tunnel and MCP bridge agent"
  homepage "https://github.com/normojs/data-proxy"
  license "AGPL-3.0-or-later"
  version "{{VERSION}}"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/normojs/data-proxy/releases/download/{{TAG}}/data-proxy-agent-{{TAG}}-darwin-arm64.tar.gz"
      sha256 "{{DARWIN_ARM64_SHA256}}"
    else
      url "https://github.com/normojs/data-proxy/releases/download/{{TAG}}/data-proxy-agent-{{TAG}}-darwin-amd64.tar.gz"
      sha256 "{{DARWIN_AMD64_SHA256}}"
    end
  end

  on_linux do
    if Hardware::CPU.arm?
      url "https://github.com/normojs/data-proxy/releases/download/{{TAG}}/data-proxy-agent-{{TAG}}-linux-arm64.tar.gz"
      sha256 "{{LINUX_ARM64_SHA256}}"
    else
      url "https://github.com/normojs/data-proxy/releases/download/{{TAG}}/data-proxy-agent-{{TAG}}-linux-amd64.tar.gz"
      sha256 "{{LINUX_AMD64_SHA256}}"
    end
  end

  def install
    bin.install Dir["data-proxy-agent-*/data-proxy-agent"].first
  end

  service do
    run [opt_bin/"data-proxy-agent", "run"]
    keep_alive true
    log_path var/"log/data-proxy-agent.log"
    error_log_path var/"log/data-proxy-agent.err.log"
  end

  test do
    system "#{bin}/data-proxy-agent", "self-test"
  end
end
