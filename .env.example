# Data Proxy 环境变量示例
#
# 首次安装推荐路径：
# 1. 启动 Data Proxy。
# 2. 打开浏览器中的初始化向导。
# 3. 在向导里测试并保存数据库 / Redis 运行配置。
# 4. 重启 Data Proxy 后继续创建首个管理员账号。
#
# 本文件主要用于高级运维覆盖。显式环境变量会优先于初始化向导
# 写入的本地 runtime-config.json。

# 端口号
# PORT=3000
# 前端基础URL
# FRONTEND_BASE_URL=https://your-frontend-url.com


# 调试相关配置
# 启用pprof
# ENABLE_PPROF=true
# 启用调试模式
# DEBUG=true
# Pyroscope 配置
# PYROSCOPE_URL=http://localhost:4040
# PYROSCOPE_APP_NAME=data-proxy
# PYROSCOPE_BASIC_AUTH_USER=your-user
# PYROSCOPE_BASIC_AUTH_PASSWORD=your-password
# PYROSCOPE_MUTEX_RATE=5
# PYROSCOPE_BLOCK_RATE=5
# HOSTNAME=your-hostname

# 数据库相关配置
# 启用错误日志记录
# ERROR_LOG_ENABLED=true
# 数据库连接字符串（高级覆盖；首次安装请优先使用初始化向导）
# SQL_DSN=user:password@tcp(127.0.0.1:3306)/dbname?parseTime=true
# Docker 访问宿主机 MySQL 示例：
# SQL_DSN=user:password@tcp(host.docker.internal:3306)/data_proxy?charset=utf8mb4&parseTime=true&loc=Local
# Docker 访问宿主机 PostgreSQL 示例：
# SQL_DSN=postgresql://user:password@host.docker.internal:5432/data_proxy
# 日志数据库连接字符串
# LOG_SQL_DSN=user:password@tcp(127.0.0.1:3306)/logdb?parseTime=true
# SQLite数据库路径
# SQLITE_PATH=/path/to/sqlite.db
# 数据库最大空闲连接数
# SQL_MAX_IDLE_CONNS=100
# 数据库最大打开连接数
# SQL_MAX_OPEN_CONNS=1000
# 数据库连接最大生命周期（秒）
# SQL_MAX_LIFETIME=60


# 部署档位（见 docs/deploy-profiles.md）
# lite     — SQLite + 进程内缓存（自用；可省略 SQL_DSN / REDIS_CONN_STRING）
# standard — MySQL/PostgreSQL + Redis
# ha       — 多节点共享 DB + Redis
# DATA_PROXY_PROFILE=lite

# 缓存相关配置
# Redis连接字符串（高级覆盖；首次安装请优先使用初始化向导；lite 可不设）
# REDIS_CONN_STRING=redis://user:password@localhost:6379/0
# Docker 访问宿主机 Redis 示例：
# REDIS_CONN_STRING=redis://:password@host.docker.internal:6379/0
# 同步频率（单位：秒）
# SYNC_FREQUENCY=60
# 内存缓存启用（渠道缓存；Redis 开启或 lite/SQLite 无 Redis 时默认开启）
# MEMORY_CACHE_ENABLED=true
# 渠道更新频率（单位：秒）
# CHANNEL_UPDATE_FREQUENCY=30
# 批量更新启用
# BATCH_UPDATE_ENABLED=true
# 批量更新间隔（单位：秒）
# BATCH_UPDATE_INTERVAL=5

# 任务和功能配置
# 更新任务启用
# UPDATE_TASK=true

# 对话超时设置
# 所有请求超时时间，单位秒，默认为0，表示不限制
# RELAY_TIMEOUT=0
# Relay HTTP 客户端空闲连接超时时间，单位秒，默认跟随 Go 标准库，设置为0表示不限制
# RELAY_IDLE_CONN_TIMEOUT=90
# 流模式无响应超时时间，单位秒，如果出现空补全可以尝试改为更大值
# STREAMING_TIMEOUT=300

# TLS / HTTP 跳过验证设置
# TLS_INSECURE_SKIP_VERIFY=false

# Gemini 识别图片 最大图片数量
# GEMINI_VISION_MAX_IMAGE_NUM=16

# 会话密钥
# SESSION_SECRET=random_string

# 其他配置
# 生成默认token
# GENERATE_DEFAULT_TOKEN=false
# Cohere 安全设置
# COHERE_SAFETY_SETTING=NONE
# 是否统计图片token
# GET_MEDIA_TOKEN=true
# 是否在非流（stream=false）情况下统计图片token
# GET_MEDIA_TOKEN_NOT_STREAM=false
# 设置 Dify 渠道是否输出工作流和节点信息到客户端
# DIFY_DEBUG=true

# LinuxDo相关配置
LINUX_DO_TOKEN_ENDPOINT=https://connect.linux.do/oauth2/token
LINUX_DO_USER_ENDPOINT=https://connect.linux.do/api/user

# 节点类型
# 如果是主节点则为master
# NODE_TYPE=master

# 企业治理 queue replay payload 清理
# ENTERPRISE_QUEUE_PAYLOAD_TTL_SECONDS=604800
# ENTERPRISE_QUEUE_PAYLOAD_CLEANUP_INTERVAL_SECONDS=3600
# ENTERPRISE_QUEUE_PAYLOAD_CLEANUP_LIMIT=500

# 企业治理审计日志保留期清理
# 默认关闭；设置保留天数后仅主节点执行。建议先开启 dry-run 观察。
# ENTERPRISE_AUDIT_LOG_RETENTION_DAYS=180
# ENTERPRISE_AUDIT_LOG_RETENTION_INTERVAL_SECONDS=86400
# ENTERPRISE_AUDIT_LOG_RETENTION_LIMIT=1000
# ENTERPRISE_AUDIT_LOG_RETENTION_DRY_RUN=true

# 企业治理 queue replay 大 payload 外部对象存储
# 未设置 ENTERPRISE_QUEUE_PAYLOAD_OBJECT_PROVIDER 时使用数据库保存 payload。
# 支持 local 或 s3；对象存储失败会自动回退数据库保存。
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_PROVIDER=local
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_DIR=/var/lib/data-proxy/enterprise-queue-payloads
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_PROVIDER=s3
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_S3_ENDPOINT=https://s3.example.com
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_S3_BUCKET=data-proxy-enterprise-queue-payloads
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_S3_REGION=us-east-1
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_S3_ACCESS_KEY=your-access-key
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_S3_SECRET_KEY=your-secret-key
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_S3_SESSION_TOKEN=optional-session-token
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_S3_KEY_PREFIX=enterprise-queue-payloads
# ENTERPRISE_QUEUE_PAYLOAD_OBJECT_S3_PATH_STYLE=true

# 请求捕获 / 诊断 / 训练数据存储
# 默认关闭。开启后 Data Proxy 会把配置命中的请求/响应写入本地 spool，
# 后续由 finalizer 打包、加密并上传到 SeaweedFS/S3-compatible 对象存储。
# CAPTURE_ENABLED=false
# CAPTURE_LEVEL=metadata
# CAPTURE_SAMPLE_RATE=1
# CAPTURE_START_TIMESTAMP=0
# CAPTURE_END_TIMESTAMP=0
# CAPTURE_SEVERITIES=warning,error
# CAPTURE_MODEL_PATTERNS=deepseek-*,qwen-*
# CAPTURE_PATH_PREFIXES=/v1/responses,/v1/chat
# CAPTURE_PROTOCOL_CHAINS=responses->chat,chat->responses
# CAPTURE_USER_IDS=1,2
# CAPTURE_TOKEN_IDS=10,11
# CAPTURE_CHANNEL_IDS=100,101
# CAPTURE_CONNECTED_APP_IDS=1000,1001
# 单个请求/响应 artifact 最大保存字节数；0 表示不限制，超出后标记 truncated 并继续请求。
# CAPTURE_MAX_ARTIFACT_BYTES=10485760
# CAPTURE_OBJECT_BACKEND=s3
# CAPTURE_SPOOL_DIR=/data/dataproxy-capture/spool
# CAPTURE_TMP_DIR=/data/dataproxy-capture/tmp
# CAPTURE_S3_ENDPOINT=http://seaweedfs:8333
# CAPTURE_S3_BUCKET=data-proxy-captures
# CAPTURE_S3_REGION=us-east-1
# CAPTURE_S3_ACCESS_KEY=your-capture-access-key
# CAPTURE_S3_SECRET_KEY=your-capture-secret-key
# CAPTURE_S3_SESSION_TOKEN=optional-session-token
# CAPTURE_S3_KEY_PREFIX=raw
# CAPTURE_S3_PATH_STYLE=true
# CAPTURE_BUNDLE_MASTER_KEY=base64:32-byte-random-key
# CAPTURE_BUNDLE_KEY_ID=local-capture-key-v1
# 诊断包下载时，最多展开多少 raw capture tar 字节；0 表示不限制。
# 超限只会在下载 zip 中写 skipped 说明，不影响正常请求和对象存储原始包。
# DIAGNOSTIC_BUNDLE_MAX_RAW_TAR_BYTES=268435456
# CAPTURE_FINALIZER_ENABLED=true
# CAPTURE_FINALIZER_INTERVAL_SECONDS=60
# CAPTURE_FINALIZER_LIMIT=100
# CAPTURE_FINALIZER_REMOVE_ON_SUCCESS=true
# CAPTURE_FINALIZER_RETRY_BASE_SECONDS=60
# CAPTURE_FINALIZER_RETRY_MAX_SECONDS=3600
# CAPTURE_SPOOL_ACTIVE_STALE_SECONDS=0
# 请求捕获留存清理。CAPTURE_RETENTION_DAYS=0 表示不按 DB/object 留存期清理；
# CAPTURE_SPOOL_RETENTION_DAYS=0 表示不按本地 spool 留存期清理。
# CAPTURE_SPOOL_WARN_BYTES=0
# 自动清理默认跟随 CAPTURE_ENABLED + CAPTURE_OBJECT_BACKEND 开启，只在 master/single-node 节点执行。
# CAPTURE_CLEANUP_ENABLED=true
# CAPTURE_RETENTION_DAYS=30
# CAPTURE_SPOOL_RETENTION_DAYS=7
# CAPTURE_CLEANUP_INTERVAL_SECONDS=3600
# CAPTURE_CLEANUP_LIMIT=500

# 可信任重定向域名列表（逗号分隔，支持子域名匹配）
# 用于验证支付成功/取消回调URL的域名安全性
# 示例: example.com,myapp.io 将允许 example.com, sub.example.com, myapp.io 等
# TRUSTED_REDIRECT_DOMAINS=example.com,myapp.io

# 微信支付商户私钥不要写入环境变量或提交到 Git。
# docker-compose.wechat-pay.yml 会将 ./secrets/wechatpay 只读挂载到容器内：
# /run/secrets/data-proxy/wechatpay
# 在控制台填写 WechatPayPrivateKeyPath：
# /run/secrets/data-proxy/wechatpay/apiclient_key.pem
