# Data Proxy — PostgreSQL + Redis 一体部署用环境变量
# 复制：cp .env.example.pg-redis .env.pg-redis
# 启动：docker compose -f docker-compose.pg-redis.yml --env-file .env.pg-redis up -d --build

# 必改
SESSION_SECRET=change-me-to-a-long-random-string

# 对外访问根（支付回调等）
FRONTEND_BASE_URL=http://localhost:3000

# 宿主机端口
DATA_PROXY_HOST_PORT=3000
TZ=Asia/Shanghai

# 内置 Postgres（compose 服务名 postgres）
POSTGRES_USER=data_proxy
POSTGRES_PASSWORD=data_proxy_change_me
POSTGRES_DB=data_proxy

# 内置 Redis
REDIS_PASSWORD=data_proxy_redis_change_me

# 一般无需改：compose 会按上面账号拼好 DSN
# SQL_DSN=postgresql://data_proxy:data_proxy_change_me@postgres:5432/data_proxy
# REDIS_CONN_STRING=redis://:data_proxy_redis_change_me@redis:6379/0

# 可选
# DATA_PROXY_IMAGE=data-proxy:latest
# NODE_NAME=data-proxy-pg-redis
# ERROR_LOG_ENABLED=true
# BATCH_UPDATE_ENABLED=true
