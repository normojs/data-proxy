# Copy this file to .env.local and fill values on your machine.
# Do not commit .env.local or paste secrets/base URLs into chat.

# Default upstream, used by GPT/Claude judge/baseline unless overridden in config.json.
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# Domestic model upstreams. These may point to official providers or separate relay routes.
QWEN_API_BASE=
QWEN_API_KEY=

MOONSHOT_API_BASE=
MOONSHOT_API_KEY=

DEEPSEEK_API_BASE=
DEEPSEEK_API_KEY=

MINIMAX_API_BASE=
MINIMAX_API_KEY=
